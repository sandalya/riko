{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pytest *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status)",
      "Bash(git commit *)",
      "Bash(rsync --checksum *)"
    ],
    "ask": [
      "Bash(git push *)"
    ],
    "deny": [
      "Read(**/*.session)",
      "Read(**/credentials.json)",
      "Read(**/*.pem)",
      "Bash(rm -rf *)"
    ]
  },
  "sandbox": {
    "filesystem": {
      "denyRead": ["~/.aws/credentials", "~/.config/gcloud"]
    }
  },
  "worktree": {
    "symlinkDirectories": ["venv", ".cache"]
  }
}